# Optional overrides for the OSS compose stack.
# Leave this file untouched for a zero-config boot: the bootstrap container
# generates strong secrets and writes /config/django.env on first run.
#
# When you need to pin specific values, copy to `.env` and override keys there.

# Core runtime toggles
#GOBII_RELEASE_ENV=oss
#DEBUG=0

# Application URLs
#PUBLIC_SITE_URL=http://localhost:8000
#CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8000,http://127.0.0.1:8000

# Optional integrations
#GOOGLE_API_KEY=
#ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#OPENROUTER_API_KEY=
# Bright Data token is shared; search and markdown scraping use product-specific zones.
#BRIGHT_DATA_TOKEN=
#BRIGHT_DATA_SERP_ZONE=
#BRIGHT_DATA_WEB_UNLOCKER_ZONE=
# Optional fallback zone for native Bright Data markdown scraping.
#BRIGHT_DATA_WEB_UNLOCKER_ZONE_FALLBACK=
# Optional per-request timeout for native Bright Data search.
#BRIGHT_DATA_SEARCH_REQUEST_TIMEOUT_SECONDS=10
# Optional maximum wait for asynchronous Bright Data dataset snapshots.
#BRIGHT_DATA_DATASET_POLL_TIMEOUT_SECONDS=600

# Sandbox compute defaults.
# The compose stacks now start the monorepo sandbox compute server by default.
# Override these only if you want a different backend or endpoint.
#SANDBOX_COMPUTE_BACKEND=http
#SANDBOX_COMPUTE_API_URL=http://sandbox-compute:8080
#SANDBOX_COMPUTE_API_TOKEN=dev-sandbox-token
#SANDBOX_COMPUTE_PORT=8080

# Observability / tracing (optional)
# Azure values are required only when running the optional collector:
#   docker compose --profile obs up
#GOBII_ENABLE_TRACING=1
#OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#OTEL_EXPORTER_OTLP_LOG_ENDPOINT=http://otel-collector:4318/v1/logs
#OTEL_EXPORTER_OTLP_INSECURE=true
#AZURE_TENANT_ID=
#AZURE_CLIENT_ID=
#AZURE_CLIENT_SECRET=
#AZURE_MONITOR_OTLP_TRACES_ENDPOINT=
#AZURE_MONITOR_OTLP_LOGS_ENDPOINT=
#AZURE_MONITOR_OTLP_METRICS_ENDPOINT=

# Object storage profile overrides (only if enabling the `object-storage` profile)
#MINIO_ROOT_USER_PREFIX=gobii
#MINIO_ROOT_USER=
#MINIO_ROOT_PASSWORD=
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#AWS_STORAGE_BUCKET_NAME=
#AWS_S3_REGION_NAME=
#AWS_S3_ENDPOINT_URL=
